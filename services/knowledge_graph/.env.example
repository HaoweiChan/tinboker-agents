# Google Cloud Project ID
PROJECT_ID=your-gcp-project-id

# Google Gemini API Key (Required for Text/Image Generation)
# Get one here: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key

# Neo4j Database Connection (Required for Persistence)
# IMPORTANT: For Neo4j Aura (Free Tier), you need the "Connection URI" and the "Password".
# 1. URI: Starts with neo4j+s:// (e.g. neo4j+s://abc12345.databases.neo4j.io)
# 2. User: Always "neo4j" for Aura.
# 3. Password: Provided ONLY when you first create the instance. 
#    If you didn't save it, go to the Aura Console -> Instance -> "Password" tab to reset it.
NEO4J_URI=neo4j+s://your-instance-id.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-reset-password

# Search API (Optional, for Agentic Search)
# Get free key: https://tavily.com
TAVILY_API_KEY=tvly-xxxxxxxxxxxx

# Deployment / API Settings
API_TIER=free
