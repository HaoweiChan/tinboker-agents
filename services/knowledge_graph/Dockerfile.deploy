# Dockerfile for Blog Post MCP API
# Deploy to Google Cloud Run

FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    build-essential \
    git \
    && rm -rf /var/lib/apt/lists/*

# Copy project files
COPY . .

# Install dependencies
RUN pip install --no-cache-dir -e ".[dev]"

# Environment variables (override in Cloud Run)
ENV PORT=8080
ENV GCS_ENABLED=true
ENV GCS_BUCKET_NAME=graphfolio-articles
ENV PYTHONUNBUFFERED=1

# Expose port
EXPOSE 8080

# Run the blog post API server
CMD ["python", "-m", "mcp.servers.blog_post_api"]

